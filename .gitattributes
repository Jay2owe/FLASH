# Line ending normalisation. mvnw.cmd is required to be CRLF for Windows.
mvnw text eol=lf
mvnw.cmd text eol=crlf
*.sh text eol=lf
*.cmd text eol=crlf
*.bat text eol=crlf
*.java text eol=lf
*.md text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.properties text=auto
# Generated artifacts and binaries
*.jar binary
*.png binary
*.jpg binary
*.tif binary
*.bin binary
*.zip binary
